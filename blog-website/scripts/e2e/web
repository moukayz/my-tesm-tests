#!/usr/bin/env bash

set -euo pipefail

ROOT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/../.." && pwd)"
ENV_APP_FILE="${ROOT_DIR}/web/.env.app"
ENV_E2E_FILE="${ROOT_DIR}/web/.env.e2e"

source "${ROOT_DIR}/scripts/_lib/env.bash"

require_cmd node "Node.js is required (Node 20+)."
require_cmd npm "npm is required (comes with Node)."

require_file "$ENV_APP_FILE" "Create it with: cp blog-website/web/.env.app.example blog-website/web/.env.app"
require_file "$ENV_E2E_FILE" "Create it with: cp blog-website/web/.env.e2e.example blog-website/web/.env.e2e"
load_env_file_no_override "$ENV_E2E_FILE"
load_env_file_no_override "$ENV_APP_FILE"

require_nonempty_env E2E_BASE_URL
require_nonempty_env E2E_API_ORIGIN

if [[ -z "${API_ORIGIN-}" ]]; then
  API_ORIGIN="$E2E_API_ORIGIN"
  export API_ORIGIN
else
  if [[ "$API_ORIGIN" != "$E2E_API_ORIGIN" ]]; then
    print_web_error_and_die "api_origin_mismatch" "API_ORIGIN must match E2E_API_ORIGIN for E2E. Fix by updating blog-website/web/.env.e2e or unsetting API_ORIGIN in your shell."
  fi
fi

derivedPort="$(node -e 'const u=new URL(process.env.E2E_BASE_URL); console.log(u.port || "");')"
if [[ -z "$derivedPort" ]]; then
  print_web_error_and_die "missing_e2e_port" "E2E_BASE_URL must include an explicit port so the web server can bind consistently."
fi

if [[ -n "${PORT-}" && "$PORT" != "$derivedPort" ]]; then
  print_web_error_and_die "port_mismatch" "PORT (${PORT}) must match the port in E2E_BASE_URL (${derivedPort})."
fi

if [[ -n "${WEB_PORT-}" && "$WEB_PORT" != "$derivedPort" ]]; then
  print_web_error_and_die "port_mismatch" "WEB_PORT (${WEB_PORT}) must match the port in E2E_BASE_URL (${derivedPort})."
fi

WEB_PORT="$derivedPort"
PORT="$derivedPort"
export PORT

printf 'WEB_ENV envFiles=%s,%s mode=e2e apiOrigin=%s\n' "blog-website/web/.env.e2e" "blog-website/web/.env.app" "$API_ORIGIN"

cd "${ROOT_DIR}/web"
run_next_dev_with_ready_signal "e2e" "$WEB_PORT"
