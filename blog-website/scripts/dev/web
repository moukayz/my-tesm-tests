#!/usr/bin/env bash

set -euo pipefail

ROOT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/../.." && pwd)"
ENV_APP_FILE="${ROOT_DIR}/web/.env.app"
ENV_LOCAL_FILE="${ROOT_DIR}/web/.env.local"

source "${ROOT_DIR}/scripts/_lib/env.bash"

require_cmd node "Node.js is required (Node 20+)."
require_cmd npm "npm is required (comes with Node)."

require_file "$ENV_APP_FILE" "Create it with: cp blog-website/web/.env.app.example blog-website/web/.env.app"
require_file "$ENV_LOCAL_FILE" "Create it with: cp blog-website/web/.env.local.example blog-website/web/.env.local"
load_env_file_no_override "$ENV_LOCAL_FILE"
load_env_file_no_override "$ENV_APP_FILE"

require_nonempty_env API_ORIGIN

if [[ -n "${PORT-}" && -n "${WEB_PORT-}" && "$PORT" != "$WEB_PORT" ]]; then
  print_web_error_and_die "port_mismatch" "PORT (${PORT}) must match WEB_PORT (${WEB_PORT})."
fi

if [[ -z "${WEB_PORT-}" ]]; then
  if [[ -z "${PORT-}" ]]; then
    print_web_error_and_die "missing_web_port" "Set WEB_PORT (preferred) or PORT in blog-website/web/.env.app or blog-website/web/.env.local."
  fi
  WEB_PORT="$PORT"
fi

if [[ -z "${PORT-}" ]]; then
  PORT="$WEB_PORT"
  export PORT
fi

printf 'WEB_ENV envFiles=%s,%s mode=dev apiOrigin=%s\n' "blog-website/web/.env.local" "blog-website/web/.env.app" "$API_ORIGIN"

cd "${ROOT_DIR}/web"
run_next_dev_with_ready_signal "dev" "$WEB_PORT"
