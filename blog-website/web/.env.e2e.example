# Playwright E2E runner overrides (higher precedence than .env.app).
# This file may contain localhost/127.0.0.1 values.

# Web origin Playwright navigates to (Playwright baseURL).
# The E2E web script derives WEB_PORT from this value.
E2E_BASE_URL=http://127.0.0.1:3001

# API origin used by tests for out-of-band setup / direct API requests
E2E_API_ORIGIN=http://127.0.0.1:3000
