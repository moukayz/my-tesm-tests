DATABASE_URL=postgres://blog:blog@localhost:5432/blog_website
RUST_LOG=info,tower_http=info,sqlx=warn

# Network
API_BIND=127.0.0.1:3000

# Cookies / sessions
SESSION_COOKIE_SECURE=false
SESSION_ABSOLUTE_TTL_SECONDS=604800
SESSION_IDLE_TTL_SECONDS=86400

# Cursor signing (recommended)
# Generate a random 32+ byte secret.
CURSOR_HMAC_SECRET=dev-insecure-change-me

# Rate limiting
AUTH_RATE_LIMIT_PER_MINUTE=20
