{
  "name": "travel-plan-web-next",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "dev:local": "DATABASE_URL=postgresql://postgres:postgres@localhost:5432/railway next dev",
    "dev:cloud": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:verbose": "jest --reporters=default",
    "test:coverage": "jest --coverage",
    "test:e2e": "playwright test --reporter=dot",
    "test:e2e:local": "DATABASE_URL=postgresql://postgres:postgres@localhost:5432/railway playwright test --reporter=dot",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:verbose": "playwright test --reporter=list",
    "db:init": "psql $DATABASE_URL -f scripts/init-db.sql",
    "db:load": "bash scripts/load-data.sh",
    "db:german:init": "psql $DATABASE_URL -f scripts/init-db-german-railway.sql",
    "db:german:load": "bash scripts/load-german-railway.sh"
  },
  "dependencies": {
    "@neondatabase/serverless": "^1.0.2",
    "@openmeteo/weather-map-layer": "^0.0.16",
    "@upstash/redis": "^1.35.6",
    "@vercel/blob": "^2.3.1",
    "duckdb": "^1.4.4",
    "jspdf": "^4.2.1",
    "jspdf-autotable": "^5.0.7",
    "lucide-react": "^0.577.0",
    "maplibre-gl": "^5.21.0",
    "next": "^15.0.0",
    "next-auth": "^5.0.0-beta.30",
    "pg": "^8.20.0",
    "pino": "^10.3.1",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "recharts": "^3.7.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/jest": "^30.0.0",
    "@types/node": "^25.3.5",
    "@types/pg": "^8.18.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "autoprefixer": "^10.0.0",
    "jest": "^30.2.0",
    "jest-environment-jsdom": "^30.2.0",
    "jest-silent-reporter": "^0.6.0",
    "pino-pretty": "^13.1.3",
    "postcss": "^8.0.0",
    "postgres": "^3.4.8",
    "tailwindcss": "^3.4.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3"
  }
}
